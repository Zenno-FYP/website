# -----------------------------------------------------------------------------
# Zenno website environment template
# Copy this file to `.env` and replace placeholder values for your environment.
# Do not commit real secrets. `.env` is ignored by git.
# -----------------------------------------------------------------------------

# Backend API base URL (the frontend appends `/api/v1` automatically if missing).
VITE_API_BASE_URL=http://localhost:3000/api/v1

# Firebase Web app configuration (from Firebase Console > Project settings).
VITE_FIREBASE_API_KEY=your-firebase-web-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-firebase-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your-messaging-sender-id
VITE_FIREBASE_APP_ID=your-firebase-app-id

# Optional: Firebase Analytics measurement ID.
VITE_FIREBASE_MEASUREMENT_ID=

# Required for browser push notifications (Firebase Cloud Messaging).
VITE_FIREBASE_VAPID_KEY=your-web-push-vapid-key

# Optional: desktop agent installer download URL.
# If empty, the "Download Agent" button is hidden in the Zenno Agent page.
VITE_DESKTOP_AGENT_DOWNLOAD_URL=
