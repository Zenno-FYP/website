VITE_API_BASE_URL=http://localhost:3000/api/v1

# Firebase Configuration
# Get these values from Firebase Console > Project Settings
# https://console.firebase.google.com/

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=

# Firebase Cloud Messaging Web Push key (Project Settings > Cloud Messaging > Web Push certificates).
# Required for browser FCM (background notifications via the service worker).
VITE_FIREBASE_VAPID_KEY=

# Optional: URL to download the Zenno desktop agent installer.
# When unset, the "Download Agent" button on the Zenno Agent page is hidden.
VITE_DESKTOP_AGENT_DOWNLOAD_URL=
